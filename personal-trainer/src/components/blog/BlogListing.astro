---
import type { CollectionEntry } from "astro:content";
import type { BlogCategory } from "../../lib/blogImages";
import BlogCard from "./BlogCard.astro";
import BlogCategoryTabs from "./BlogCategoryTabs.astro";
import BlogPagination from "./BlogPagination.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  activeCategory?: BlogCategory | "All";
  currentPage?: number;
  lastPage?: number;
  basePath?: string;
}

const {
  posts,
  activeCategory = "All",
  currentPage = 1,
  lastPage = 1,
  basePath = "/blog",
} = Astro.props;
---

<BlogCategoryTabs activeCategory={activeCategory} />

<div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
  {
    posts.length > 0 ? (
      posts.map((post) => <BlogCard post={post} />)
    ) : (
      <p class="col-span-full text-center text-white/60">
        No articles in this category yet.
      </p>
    )
  }
</div>

<BlogPagination
  currentPage={currentPage}
  lastPage={lastPage}
  basePath={basePath}
/>
