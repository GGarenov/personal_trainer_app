---
import { blogCategories } from "../../lib/blogImages";
import { categoryToSlug } from "../../lib/blog";
import type { BlogCategory } from "../../lib/blogImages";

interface Props {
  activeCategory?: BlogCategory | "All";
}

const { activeCategory = "All" } = Astro.props;

const tabs: { label: string; href: string; key: BlogCategory | "All" }[] = [
  { label: "All", href: "/blog/", key: "All" },
  ...blogCategories.map((category) => ({
    label: category,
    href: `/blog/category/${categoryToSlug(category)}/`,
    key: category,
  })),
];
---

<nav aria-label="Filter posts by category" class="mt-10 flex flex-wrap gap-2">
  {
    tabs.map((tab) => (
      <a
        href={tab.href}
        class:list={[
          "rounded-full border px-4 py-2 text-sm font-semibold uppercase tracking-wider transition-colors",
          activeCategory === tab.key
            ? "border-primary bg-primary text-dark"
            : "border-white/20 text-white/70 hover:border-primary hover:text-primary",
        ]}
        aria-current={activeCategory === tab.key ? "page" : undefined}
      >
        {tab.label}
      </a>
    ))
  }
</nav>
