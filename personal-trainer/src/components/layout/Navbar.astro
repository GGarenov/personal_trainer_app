---
import CartIcon from "../shared/CartIcon.jsx";

const pathname = Astro.url.pathname;

const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Training Programs", href: "/programs" },
  { name: "Nutrition Plans", href: "/nutrition" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
];

const isActive = (href) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-black/70 border-b border-white/10">
  <nav
    aria-label="Main navigation"
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6"
  >

    <!-- LOGO -->

    <a
      href="/"
      class="group flex items-center gap-3 transition-opacity hover:opacity-90"
      aria-label="George Stevens Fitness — Home"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center border border-primary/30 font-heading text-2xl font-bold leading-none text-primary transition-colors group-hover:border-primary/60"
      >
        GS
      </span>

      <span class="flex flex-col leading-none">
        <span class="font-heading text-lg font-bold tracking-[0.18em] text-white sm:text-xl">
          GEORGE STEVENS
        </span>
        <span class="mt-1 font-body text-[0.65rem] font-black uppercase tracking-[0.42em] text-white/75 sm:text-xs">
          fitness
        </span>
      </span>
    </a>

    <!-- MOBILE TOGGLE -->

    <input id="menu-toggle" type="checkbox" class="peer hidden" />

    <label
      for="menu-toggle"
      class="cursor-pointer md:hidden"
      aria-label="Toggle menu"
    >
      <div class="space-y-1">
        <span class="block h-0.5 w-6 bg-white"></span>
        <span class="block h-0.5 w-6 bg-white"></span>
        <span class="block h-0.5 w-6 bg-white"></span>
      </div>
    </label>

    <!-- NAV LINKS -->

    <ul
      class="
      absolute left-0 top-20 hidden w-full flex-col
      bg-black/95 px-6 py-6
      peer-checked:flex
      md:static md:flex md:w-auto md:flex-row
      md:items-center md:gap-8 md:bg-transparent
    "
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`transition-colors duration-200
              ${
                isActive(link.href)
                  ? "text-primary font-semibold"
                  : "text-white hover:text-primary"
              }`}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- RIGHT SIDE -->

    <div class="hidden md:flex items-center">
      <CartIcon client:load />
    </div>

  </nav>

  <!-- MOBILE CART -->

  <div class="absolute right-16 top-7 md:hidden">
    <CartIcon client:load />
  </div>

</header>