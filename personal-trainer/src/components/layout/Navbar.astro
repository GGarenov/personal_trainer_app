---
import CartIcon from "../shared/CartIcon.jsx";
import { navLinks } from "../../config/navigation";

const pathname = Astro.url.pathname;

const links = navLinks;

const isActive = (href) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

const focusRing =
  "rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-black";

const linkClass = (link) => {
  const active = isActive(link.href);

  if (link.cta) {
    return active
      ? `${focusRing} rounded bg-primary/90 px-4 py-2 text-sm font-semibold uppercase tracking-wider text-dark`
      : `${focusRing} rounded bg-primary px-4 py-2 text-sm font-semibold uppercase tracking-wider text-dark transition-colors hover:bg-primary/90`;
  }

  return `${focusRing} ${
    active ? "font-semibold text-primary" : "text-white hover:text-primary"
  }`;
};

const mobileLinkClass = (link) => {
  const active = isActive(link.href);

  if (link.cta) {
    return `${focusRing} ${
      active
        ? "bg-primary/90 text-dark"
        : "bg-primary text-dark hover:bg-primary/90"
    }`;
  }

  return `${focusRing} ${active ? "text-primary" : "text-white hover:text-primary"}`;
};

const mobileLinks = [
  ...links.filter((link) => link.cta),
  ...links.filter((link) => !link.cta),
];
---

<header id="site-header" class="sticky top-0 z-50">
  <!-- Promo / quiz bar -->
  <div id="promo-bar" class="relative bg-primary text-dark">
    <div class="mx-auto flex max-w-7xl items-center justify-center px-10 py-2 text-center sm:px-6">
      <a
        href="/program-selector"
        class="group inline-flex flex-wrap items-center justify-center gap-x-2 gap-y-0.5 text-xs font-medium sm:text-sm"
      >
        <span class="inline-flex items-center gap-1.5">
          <svg
            class="h-3.5 w-3.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M9.09 9a3 3 0 1 1 5.83 1c0 2-3 3-3 3" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
          Not sure which program is right for you?
        </span>
        <span
          class="inline-flex items-center gap-1 font-bold underline decoration-2 underline-offset-2 transition-all group-hover:gap-2"
        >
          Take the free 60-second quiz
          <svg
            class="h-3.5 w-3.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      </a>
      <button
        id="promo-dismiss"
        type="button"
        aria-label="Dismiss"
        class="absolute right-2 top-1/2 -translate-y-1/2 rounded p-1.5 text-dark/60 transition-colors hover:bg-dark/10 hover:text-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dark sm:right-4"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    aria-label="Main navigation"
    class="border-b border-white/10 bg-black/70 backdrop-blur-md"
  >
    <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
    <a
      href="/"
      class="group flex items-center gap-3"
      aria-label="George Stevens Fitness — Home"
    >
      <span
        class="relative flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary font-heading text-[1.7rem] font-bold leading-none text-dark shadow-lg shadow-primary/20 ring-1 ring-primary/50 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-primary/40"
      >
        GS
        <span
          class="pointer-events-none absolute -bottom-1 -right-1 h-2.5 w-2.5 rounded-full bg-primary ring-2 ring-black"
        ></span>
      </span>

      <span class="flex flex-col leading-none">
        <span class="font-heading text-xl tracking-[0.2em] text-white sm:text-2xl">
          GEORGE <span class="text-primary">STEVENS</span>
        </span>
        <span class="mt-1 flex items-center gap-2">
          <span class="h-px w-4 bg-primary/60"></span>
          <span class="font-body text-[0.6rem] font-bold uppercase tracking-[0.4em] text-white/60">
            fitness
          </span>
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`transition-colors duration-200 ${linkClass(link)}`}
              {...(isActive(link.href) ? { "aria-current": "page" } : {})}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-5">
      <CartIcon client:load />

      <label
        for="menu-toggle"
        class={`${focusRing} cursor-pointer p-1 md:hidden`}
        aria-label="Open menu"
      >
        <div class="space-y-1.5">
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
        </div>
      </label>
    </div>
    </div>
  </nav>
</header>

<input id="menu-toggle" type="checkbox" class="peer hidden" />

<label
  for="menu-toggle"
  class="pointer-events-none fixed inset-0 z-[80] bg-black/70 opacity-0 transition-opacity duration-300 peer-checked:pointer-events-auto peer-checked:opacity-100 md:hidden"
  aria-hidden="true"
></label>

<aside
  id="mobile-menu"
  class="fixed left-0 top-0 z-[90] flex h-dvh min-h-dvh w-[min(100%,20rem)] -translate-x-full flex-col bg-black shadow-2xl transition-transform duration-300 ease-out peer-checked:translate-x-0 md:hidden"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="flex items-center justify-between border-b border-white/10 bg-black px-6 py-5">
    <a href="/" data-menu-link class="flex items-center gap-2" aria-label="George Stevens Fitness — Home">
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary font-heading text-xl font-bold leading-none text-dark ring-1 ring-primary/50"
      >
        GS
      </span>
      <span class="font-heading text-lg tracking-[0.2em] text-white">
        GEORGE <span class="text-primary">STEVENS</span>
      </span>
    </a>
    <label
      for="menu-toggle"
      class={`${focusRing} cursor-pointer p-1 text-white transition-colors hover:text-primary`}
      aria-label="Close menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </label>
  </div>

  <ul class="flex flex-1 flex-col bg-black">
    <li class="border-b border-white/10">
      <a
        href="/program-selector"
        data-menu-link
        class={`${focusRing} flex items-center justify-between gap-2 bg-primary/10 px-6 py-4 font-heading text-2xl tracking-wider text-primary transition-colors hover:bg-primary/20`}
        {...(isActive("/program-selector") ? { "aria-current": "page" } : {})}
      >
        FIND MY PROGRAM
        <svg
          class="h-5 w-5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </li>
    {
      mobileLinks.map((link) => (
        <li class:list={[link.cta ? "px-6 pt-6 pb-2" : "border-b border-white/10"]}>
          <a
            href={link.href}
            data-menu-link
            class:list={[
              "block transition-colors",
              link.cta
                ? `rounded px-6 py-4 text-center font-heading text-2xl font-semibold uppercase tracking-wider ${mobileLinkClass(link)}`
                : `px-6 py-4 font-heading text-2xl tracking-wider ${mobileLinkClass(link)}`,
            ]}
            {...(isActive(link.href) ? { "aria-current": "page" } : {})}
          >
            {link.name.toUpperCase()}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  const toggle = document.getElementById("menu-toggle") as HTMLInputElement | null;
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    const syncMenuState = () => {
      menu.setAttribute("aria-hidden", toggle.checked ? "false" : "true");
      document.body.style.overflow = toggle.checked ? "hidden" : "";
    };

    toggle.addEventListener("change", syncMenuState);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.checked) {
        toggle.checked = false;
        syncMenuState();
      }
    });

    document.querySelectorAll("[data-menu-link]").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.checked = false;
        syncMenuState();
      });
    });
  }

  const promoBar = document.getElementById("promo-bar");
  const promoDismiss = document.getElementById("promo-dismiss");

  if (promoBar && promoDismiss) {
    if (sessionStorage.getItem("promoDismissed") === "true") {
      promoBar.style.display = "none";
    }

    promoDismiss.addEventListener("click", () => {
      promoBar.style.display = "none";
      sessionStorage.setItem("promoDismissed", "true");
    });
  }
</script>
