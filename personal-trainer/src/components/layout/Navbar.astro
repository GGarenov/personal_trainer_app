---
import CartIcon from "../shared/CartIcon";
import { navLinks, type NavLink } from "../../config/navigation";

const pathname = Astro.url.pathname;

const links = navLinks;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

const focusRing =
  "rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-black";

const navBtnClass =
  "inline-flex items-center justify-center whitespace-nowrap rounded px-4 py-2 text-sm font-semibold uppercase tracking-wider transition-colors duration-200";

const linkClass = (link: NavLink) => {
  const active = isActive(link.href);

  if (link.cta) {
    return active
      ? `${focusRing} ${navBtnClass} bg-primary/90 text-dark`
      : `${focusRing} ${navBtnClass} bg-primary text-dark hover:bg-primary/90`;
  }

  return `${focusRing} inline-flex items-center ${
    active ? "font-semibold text-primary" : "text-white hover:text-primary"
  }`;
};

const mobileLinkClass = (link: NavLink) => {
  const active = isActive(link.href);

  if (link.cta) {
    return `${focusRing} ${
      active
        ? "bg-primary/90 text-dark"
        : "bg-primary text-dark hover:bg-primary/90"
    }`;
  }

  return `${focusRing} ${active ? "text-primary" : "text-white hover:text-primary"}`;
};

const mobileLinks = [
  ...links.filter((link) => link.cta),
  ...links.filter((link) => !link.cta),
];

const quizActive = isActive("/program-selector");

const quizBtnClass = quizActive
  ? `${focusRing} ${navBtnClass} border border-primary bg-primary text-dark`
  : `${focusRing} ${navBtnClass} border border-white/25 text-white hover:border-primary hover:bg-primary hover:text-dark`;

const standardLinks = links.filter((link) => !link.cta);
const ctaLinks = links.filter((link) => link.cta);
---

<header id="site-header" class="sticky top-0 z-50">
  <!-- Promo / quiz bar -->
  <div id="promo-bar" class="bg-primary text-dark">
    <div class="mx-auto flex max-w-7xl items-center justify-center px-6 py-2 text-center">
      <a
        href="/program-selector"
        class="group inline-flex flex-wrap items-center justify-center gap-x-2 gap-y-0.5 text-xs font-medium sm:text-sm"
      >
        <span class="inline-flex items-center gap-1.5">
          <svg
            class="h-3.5 w-3.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M9.09 9a3 3 0 1 1 5.83 1c0 2-3 3-3 3" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
          Not sure which program is right for you?
        </span>
        <span
          class="inline-flex items-center gap-1 font-bold underline decoration-2 underline-offset-2 transition-all group-hover:gap-2"
        >
          Take the free 60-second quiz
          <svg
            class="h-3.5 w-3.5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      </a>
    </div>
  </div>

  <nav
    aria-label="Main navigation"
    class="border-b border-white/10 bg-black/70 backdrop-blur-md"
  >
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-6 lg:h-[4.5rem]">
    <a
      href="/"
      class="group flex shrink-0 items-center gap-2.5 lg:gap-3"
      aria-label="George Stevens Fitness — Home"
    >
      <span
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary font-heading text-2xl font-bold leading-none text-dark ring-1 ring-primary/50 transition-shadow duration-300 group-hover:shadow-lg group-hover:shadow-primary/30"
      >
        GS
      </span>

      <span class="flex flex-col justify-center leading-none">
        <span class="font-heading text-lg tracking-[0.18em] text-white lg:text-xl">
          GEORGE <span class="text-primary">STEVENS</span>
        </span>
        <span class="mt-0.5 hidden items-center gap-2 sm:flex">
          <span class="h-px w-3 bg-primary/60"></span>
          <span class="font-body text-[0.55rem] font-bold uppercase tracking-[0.35em] text-white/60">
            fitness
          </span>
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-5 lg:gap-6 xl:gap-8 md:flex">
      {
        standardLinks.map((link) => (
          <li class="flex items-center">
            <a
              href={link.href}
              class={`text-sm transition-colors duration-200 ${linkClass(link)}`}
              {...(isActive(link.href) ? { "aria-current": "page" } : {})}
            >
              {link.name}
            </a>
          </li>
        ))
      }
      <li class="flex items-center">
        <a
          href="/program-selector"
          class={quizBtnClass}
          {...(quizActive ? { "aria-current": "page" } : {})}
        >
          Find my program
        </a>
      </li>
      {
        ctaLinks.map((link) => (
          <li class="flex items-center">
            <a
              href={link.href}
              class={linkClass(link)}
              {...(isActive(link.href) ? { "aria-current": "page" } : {})}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex shrink-0 items-center gap-4">
      <CartIcon client:load />

      <label
        for="menu-toggle"
        class={`${focusRing} cursor-pointer p-1 md:hidden`}
        aria-label="Open menu"
      >
        <div class="space-y-1.5">
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
        </div>
      </label>
    </div>
    </div>
  </nav>
</header>

<input id="menu-toggle" type="checkbox" class="peer hidden" />

<label
  for="menu-toggle"
  class="pointer-events-none fixed inset-0 z-[80] bg-black/70 opacity-0 transition-opacity duration-300 peer-checked:pointer-events-auto peer-checked:opacity-100 md:hidden"
  aria-hidden="true"
></label>

<aside
  id="mobile-menu"
  class="fixed left-0 top-0 z-[90] flex h-dvh min-h-dvh w-[min(100%,20rem)] -translate-x-full flex-col bg-black shadow-2xl transition-transform duration-300 ease-out peer-checked:translate-x-0 md:hidden"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="flex items-center justify-between border-b border-white/10 bg-black px-6 py-5">
    <a href="/" data-menu-link class="flex items-center gap-2" aria-label="George Stevens Fitness — Home">
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary font-heading text-xl font-bold leading-none text-dark ring-1 ring-primary/50"
      >
        GS
      </span>
      <span class="font-heading text-lg tracking-[0.2em] text-white">
        GEORGE <span class="text-primary">STEVENS</span>
      </span>
    </a>
    <label
      for="menu-toggle"
      class={`${focusRing} cursor-pointer p-1 text-white transition-colors hover:text-primary`}
      aria-label="Close menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </label>
  </div>

  <ul class="flex flex-1 flex-col bg-black">
    <li class="border-b border-white/10">
      <a
        href="/program-selector"
        data-menu-link
        class={`${focusRing} flex items-center justify-between gap-2 px-6 py-4 font-heading text-xl tracking-wider text-white transition-colors hover:bg-primary/10 hover:text-primary`}
        {...(isActive("/program-selector") ? { "aria-current": "page" } : {})}
      >
        Find my program
        <svg
          class="h-5 w-5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </li>
    {
      mobileLinks.map((link) => (
        <li class:list={[link.cta ? "px-6 pt-6 pb-2" : "border-b border-white/10"]}>
          <a
            href={link.href}
            data-menu-link
            class:list={[
              "block transition-colors",
              link.cta
                ? `rounded px-6 py-4 text-center font-heading text-2xl font-semibold uppercase tracking-wider ${mobileLinkClass(link)}`
                : `px-6 py-4 font-heading text-2xl tracking-wider ${mobileLinkClass(link)}`,
            ]}
            {...(isActive(link.href) ? { "aria-current": "page" } : {})}
          >
            {link.name.toUpperCase()}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  const toggle = document.getElementById("menu-toggle") as HTMLInputElement | null;
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    const syncMenuState = () => {
      menu.setAttribute("aria-hidden", toggle.checked ? "false" : "true");
      document.body.style.overflow = toggle.checked ? "hidden" : "";
    };

    toggle.addEventListener("change", syncMenuState);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.checked) {
        toggle.checked = false;
        syncMenuState();
      }
    });

    document.querySelectorAll("[data-menu-link]").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.checked = false;
        syncMenuState();
      });
    });
  }

</script>
