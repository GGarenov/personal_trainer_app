---
import CartIcon from "../shared/CartIcon.jsx";

const pathname = Astro.url.pathname;

const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Training Programs", href: "/programs" },
  { name: "Nutrition Plans", href: "/nutrition" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
  { name: "Book", href: "/book", cta: true },
];

const isActive = (href) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

const focusRing =
  "rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-black";

const linkClass = (link) => {
  const active = isActive(link.href);

  if (link.cta) {
    return active
      ? `${focusRing} rounded bg-primary/90 px-4 py-2 text-sm font-semibold uppercase tracking-wider text-dark`
      : `${focusRing} rounded bg-primary px-4 py-2 text-sm font-semibold uppercase tracking-wider text-dark transition-colors hover:bg-primary/90`;
  }

  return `${focusRing} ${
    active ? "font-semibold text-primary" : "text-white hover:text-primary"
  }`;
};

const mobileLinkClass = (link) => {
  const active = isActive(link.href);

  if (link.cta) {
    return `${focusRing} ${
      active
        ? "bg-primary/90 text-dark"
        : "bg-primary text-dark hover:bg-primary/90"
    }`;
  }

  return `${focusRing} ${active ? "text-primary" : "text-white hover:text-primary"}`;
};

const mobileLinks = [
  ...links.filter((link) => link.cta),
  ...links.filter((link) => !link.cta),
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-black/70 backdrop-blur-md">
  <nav
    aria-label="Main navigation"
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6"
  >
    <a
      href="/"
      class="group flex items-center gap-3 transition-opacity hover:opacity-90"
      aria-label="George Stevens Fitness — Home"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center border border-primary/30 font-heading text-2xl font-bold leading-none text-primary transition-colors group-hover:border-primary/60"
      >
        GS
      </span>

      <span class="flex flex-col leading-none">
        <span class="font-heading text-lg font-bold tracking-[0.18em] text-white sm:text-xl">
          GEORGE STEVENS
        </span>
        <span class="mt-1 font-body text-[0.65rem] font-black uppercase tracking-[0.42em] text-white/75 sm:text-xs">
          fitness
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class={`transition-colors duration-200 ${linkClass(link)}`}
              {...(isActive(link.href) ? { "aria-current": "page" } : {})}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-5">
      <CartIcon client:load />

      <label
        for="menu-toggle"
        class={`${focusRing} cursor-pointer p-1 md:hidden`}
        aria-label="Open menu"
      >
        <div class="space-y-1.5">
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
          <span class="block h-0.5 w-6 bg-white"></span>
        </div>
      </label>
    </div>
  </nav>
</header>

<input id="menu-toggle" type="checkbox" class="peer hidden" />

<label
  for="menu-toggle"
  class="pointer-events-none fixed inset-0 z-[80] bg-black/70 opacity-0 transition-opacity duration-300 peer-checked:pointer-events-auto peer-checked:opacity-100 md:hidden"
  aria-hidden="true"
></label>

<aside
  id="mobile-menu"
  class="fixed left-0 top-0 z-[90] flex h-dvh min-h-dvh w-[min(100%,20rem)] -translate-x-full flex-col bg-black shadow-2xl transition-transform duration-300 ease-out peer-checked:translate-x-0 md:hidden"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="flex items-center border-b border-white/10 bg-black px-6 py-5">
    <label
      for="menu-toggle"
      class={`${focusRing} cursor-pointer p-1 text-white transition-colors hover:text-primary`}
      aria-label="Close menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </label>
  </div>

  <ul class="flex flex-1 flex-col bg-black">
    {
      mobileLinks.map((link) => (
        <li class:list={[link.cta ? "px-6 pt-6 pb-2" : "border-b border-white/10"]}>
          <a
            href={link.href}
            data-menu-link
            class:list={[
              "block transition-colors",
              link.cta
                ? `rounded px-6 py-4 text-center font-heading text-2xl font-semibold uppercase tracking-wider ${mobileLinkClass(link)}`
                : `px-6 py-4 font-heading text-2xl tracking-wider ${mobileLinkClass(link)}`,
            ]}
            {...(isActive(link.href) ? { "aria-current": "page" } : {})}
          >
            {link.name.toUpperCase()}
          </a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  const toggle = document.getElementById("menu-toggle") as HTMLInputElement | null;
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    const syncMenuState = () => {
      menu.setAttribute("aria-hidden", toggle.checked ? "false" : "true");
      document.body.style.overflow = toggle.checked ? "hidden" : "";
    };

    toggle.addEventListener("change", syncMenuState);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.checked) {
        toggle.checked = false;
        syncMenuState();
      }
    });

    document.querySelectorAll("[data-menu-link]").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.checked = false;
        syncMenuState();
      });
    });
  }
</script>
