---
const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Training Programs", href: "/programs" },
  { name: "Nutrition Plans", href: "/nutrition" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
];
---

<footer class="border-t border-white/10 bg-surface mt-20">

  <!-- MAIN FOOTER -->

  <div
    class="
    mx-auto
    max-w-7xl
    px-6
    py-14
    grid
    gap-12
    md:grid-cols-3
    "
  >

    <!-- LEFT COLUMN -->

    <div class="space-y-4">

      <a
        href="/"
        class="font-heading text-3xl tracking-wider text-white"
      >
        TRAINER
      </a>

      <p class="max-w-xs text-sm text-gray-400">
        Science-based training programs and nutrition plans
        built to help you transform your physique.
      </p>

    </div>

    <!-- MIDDLE COLUMN -->

    <div>

      <h3 class="mb-5 font-semibold uppercase tracking-wider text-primary">
        Quick Links
      </h3>

      <ul class="space-y-3">

        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="
                text-gray-300
                transition-colors
                duration-200
                hover:text-primary
                "
              >
                {link.name}
              </a>
            </li>
          ))
        }

      </ul>

    </div>

    <!-- RIGHT COLUMN -->

    <div>

      <h3 class="mb-5 font-semibold uppercase tracking-wider text-primary">
        Follow Me
      </h3>

      <div class="flex gap-5">

        <!-- Instagram -->

        <a
          href="#"
          aria-label="Instagram"
          class="text-gray-300 hover:text-primary transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1"/>
          </svg>
        </a>

        <!-- Youtube -->

        <a
          href="#"
          aria-label="YouTube"
          class="text-gray-300 hover:text-primary transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M23 12s0-3.5-.4-5.2c-.2-.9-.9-1.6-1.8-1.8C19.1 4.5 12 4.5 12 4.5s-7.1 0-8.8.5c-.9.2-1.6.9-1.8 1.8C1 8.5 1 12 1 12s0 3.5.4 5.2c.2.9.9 1.6 1.8 1.8 1.7.5 8.8.5 8.8.5s7.1 0 8.8-.5c.9-.2 1.6-.9 1.8-1.8.4-1.7.4-5.2.4-5.2z"/>
            <path fill="black" d="M10 15.5v-7l6 3.5z"/>
          </svg>
        </a>

        <!-- Facebook -->

        <a
          href="#"
          aria-label="Facebook"
          class="text-gray-300 hover:text-primary transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v8h4v-8h3l1-4h-4v-3c0-.7.3-1 1-1z"/>
          </svg>
        </a>

        <!-- TikTok -->

        <a
          href="#"
          aria-label="TikTok"
          class="text-gray-300 hover:text-primary transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M16 3c.3 2.2 1.5 3.7 4 4v3c-1.4 0-2.7-.4-4-1.2V16c0 3.3-2.7 6-6 6s-6-2.7-6-6 2.7-6 6-6c.3 0 .6 0 .9.1v3.2c-.3-.1-.6-.2-.9-.2-1.7 0-3 1.3-3 3s1.3 3 3 3 3-1.3 3-3V3h3z"/>
          </svg>
        </a>

      </div>

    </div>

  </div>

  <!-- BOTTOM BAR -->

  <div
    class="
    border-t
    border-white/10
    px-6
    py-5
    text-center
    text-sm
    text-gray-500
    "
  >
    © 2026 TRAINER. All Rights Reserved.
  </div>

</footer>