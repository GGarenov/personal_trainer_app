---
import { Image } from "astro:assets";
import ProgramPurchase from "./ProgramPurchase";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Product } from "../../data/products";
import { getProductCover } from "../../lib/productImages";
import {
  nutritionIconPaths,
  trainingIncludedIcons,
  trustBadges,
} from "../../lib/productDetailIcons";

export type ProductDetailVariant = "training" | "nutrition";

interface Props {
  product: Product;
  parentHref: string;
  parentLabel: string;
  variant: ProductDetailVariant;
}

const { product, parentHref, parentLabel, variant } = Astro.props;

const detail = product.detail;
const cover = getProductCover(product.image);
const ratingValue = detail?.rating ?? 0;
const fullStars = Math.round(ratingValue);
const isTraining = variant === "training";

const descriptionFallback = isTraining
  ? `${product.name} training program.`
  : `${product.name} nutrition plan.`;

const purchaseOptionLabel = isTraining
  ? "Training Split"
  : (detail?.optionLabel ?? "Plan Format");

const ratingAudience = isTraining ? "lifters" : "clients";

const whatsNewBlurb = isTraining
  ? "A complete, science-based system you can run from your phone in the gym — built to deliver results without wasted time."
  : "A complete, science-based nutrition system you can follow from your phone — built to deliver results that last.";

const ctaDescription = isTraining
  ? "Get instant access to the full program, video library and tracking tools — and start training with purpose today."
  : "Get instant access to the full nutrition plan, meal guides and tracking tools — and start eating with purpose today.";

const ctaBrowseHref = isTraining ? "/programs" : "/nutrition";
const ctaBrowseLabel = isTraining
  ? "Browse all training programs"
  : "Browse all nutrition plans";

const ctaTitle = isTraining
  ? `Ready to start ${product.name}?`
  : `Ready to start the ${product.name}?`;

const purchaseProduct = {
  id: product.id,
  name: product.name,
  price: product.price,
  image: product.image,
};
---

<BaseLayout
  title={`${product.name} — George Stevens`}
  description={detail?.tagline ?? descriptionFallback}
  ogImage={cover}
  ogType="product"
>
  <main>
    <!-- Product header -->
    <section class="border-b border-white/10 bg-surface/40">
      <div class="mx-auto max-w-7xl px-6 py-8 md:py-12">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex flex-wrap items-center gap-2 text-sm text-white/50">
            <li><a href="/" class="transition-colors hover:text-primary">Home</a></li>
            <li><span aria-hidden="true">/</span></li>
            <li>
              <a href={parentHref} class="transition-colors hover:text-primary">
                {parentLabel}
              </a>
            </li>
            <li><span aria-hidden="true">/</span></li>
            <li><span class="text-white/80">{product.name}</span></li>
          </ol>
        </nav>

        <div class="grid gap-10 md:grid-cols-2 md:items-start">
          <div class="overflow-hidden rounded-2xl border border-white/10 bg-dark">
            <Image
              src={cover}
              alt={product.name}
              class="aspect-square w-full object-cover"
              widths={[480, 720, 960]}
              sizes="(max-width: 768px) 100vw, 45vw"
              loading="eager"
              decoding="async"
              quality={80}
            />
          </div>

          <div class="md:py-2">
            {
              detail?.badges && detail.badges.length > 0 && (
                <div class="mb-4 flex flex-wrap gap-2">
                  {detail.badges.map((badge) => (
                    <span class="rounded bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wider text-dark">
                      {badge}
                    </span>
                  ))}
                </div>
              )
            }

            <h1 class="font-heading text-4xl tracking-wider text-white md:text-5xl">
              {product.name}
            </h1>

            {
              detail?.tagline && (
                <p class="mt-4 text-base text-white/70">{detail.tagline}</p>
              )
            }

            {
              detail && (
                <div class="mt-5 flex items-center gap-3">
                  <div class="flex" aria-hidden="true">
                    {Array.from({ length: 5 }).map((_, index) => (
                      <svg
                        class:list={[
                          "h-5 w-5",
                          index < fullStars ? "text-primary" : "text-white/20",
                        ]}
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.447a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118l-3.367-2.447a1 1 0 00-1.175 0l-3.367 2.447c-.784.57-1.838-.196-1.539-1.118l1.286-3.957a1 1 0 00-.363-1.118L2.075 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.957z" />
                      </svg>
                    ))}
                  </div>
                  <span class="text-sm text-white/60">
                    {ratingValue.toFixed(1)} · {detail.reviews} reviews
                  </span>
                </div>
              )
            }

            <p class="mt-6 font-heading text-5xl tracking-wide text-primary">
              €{product.price}
            </p>

            <div class="mt-6">
              <ProgramPurchase
                client:load
                product={purchaseProduct}
                splits={detail?.splits ?? []}
                optionLabel={purchaseOptionLabel}
              />
            </div>

            {
              detail?.includedItems && detail.includedItems.length > 0 && (
                <div class="mt-8 border-t border-white/10 pt-6">
                  <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-white/60">
                    What's included
                  </p>
                  <ul class="space-y-2">
                    {detail.includedItems.map((item) => (
                      <li class="flex items-center gap-2 text-sm text-white/80">
                        <span class="text-primary" aria-hidden="true">✓</span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )
            }

            <div class="mt-8 grid grid-cols-3 gap-4 border-t border-white/10 pt-6">
              {
                trustBadges.map((badge) => (
                  <div class="flex flex-col items-center gap-2 text-center">
                    <svg
                      class="h-7 w-7 text-primary"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={badge.icon}
                      />
                    </svg>
                    <span class="text-xs text-white/60">{badge.label}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- You Will Get (nutrition only) -->
    {
      !isTraining && detail?.youWillGet && detail.youWillGet.length > 0 && (
        <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
          <h2 class="font-heading text-3xl tracking-wider text-white md:text-4xl">
            You Will Get
          </h2>
          {detail.youWillGetIntro && (
            <p class="mt-3 max-w-2xl text-white/60">{detail.youWillGetIntro}</p>
          )}

          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {detail.youWillGet.map((card) => (
              <article class="flex flex-col rounded-xl border border-white/10 bg-surface p-6 transition-colors hover:border-white/20">
                <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                  <svg
                    class="h-6 w-6 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d={nutritionIconPaths[card.icon] ?? nutritionIconPaths.meal}
                    />
                  </svg>
                </span>
                <h3 class="font-heading text-xl tracking-wide text-white">
                  {card.title}
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-white/70">
                  {card.body}
                </p>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <!-- What's New -->
    {
      detail?.whatsNew && detail.whatsNew.length > 0 && (
        <section
          class:list={[
            isTraining
              ? "mx-auto max-w-7xl px-6 py-16 md:py-24"
              : "border-y border-white/10 bg-surface/40 py-16 md:py-24",
          ]}
        >
          <div class:list={[!isTraining && "mx-auto max-w-7xl px-6"]}>
            <h2
              class:list={[
                "font-heading text-3xl tracking-wider text-white md:text-4xl",
                isTraining ? "mb-10" : "mb-10",
              ]}
            >
              What's New?
            </h2>
            <div class="grid gap-10 md:grid-cols-2 md:items-start">
              <div class="space-y-3">
                {detail.whatsNew.map((feature, index) => (
                  <details
                    class:list={[
                      "group rounded-xl border border-white/10 px-5 py-4 transition-colors hover:border-white/20",
                      isTraining ? "bg-surface" : "bg-dark",
                    ]}
                    open={index === 0}
                  >
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-heading text-xl tracking-wide text-white">
                      <span class="flex items-center gap-3">
                        <svg
                          class="h-5 w-5 shrink-0 text-primary"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                          />
                        </svg>
                        {feature.title}
                      </span>
                      <span
                        class="text-2xl leading-none text-white/40 transition-transform group-open:rotate-45"
                        aria-hidden="true"
                      >
                        +
                      </span>
                    </summary>
                    <p class="mt-3 pl-8 text-sm leading-relaxed text-white/70">
                      {feature.body}
                    </p>
                  </details>
                ))}
              </div>

              <div
                class:list={[
                  "flex h-full items-center justify-center rounded-2xl border border-white/10 p-8",
                  isTraining ? "bg-surface/60" : "bg-dark",
                ]}
              >
                <div class="text-center">
                  <p class="font-heading text-6xl tracking-wide text-primary">
                    {ratingValue.toFixed(1)}/5
                  </p>
                  <p class="mt-2 text-sm text-white/60">
                    Rated by {detail.reviews} {ratingAudience}
                  </p>
                  <p class="mt-6 max-w-xs text-sm leading-relaxed text-white/70">
                    {whatsNewBlurb}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- What's Included (training only) -->
    {
      isTraining &&
        detail?.whatsIncluded &&
        detail.whatsIncluded.length > 0 && (
          <section class="border-y border-white/10 bg-surface/40 py-16 md:py-24">
            <div class="mx-auto max-w-7xl px-6">
              <h2 class="mb-10 font-heading text-3xl tracking-wider text-white md:text-4xl">
                What's Included
              </h2>

              <div class="grid gap-6 md:grid-cols-3">
                {detail.whatsIncluded.map((feature, index) => (
                  <article class="flex flex-col rounded-xl border border-white/10 bg-dark p-6">
                    <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10">
                      <svg
                        class="h-6 w-6 text-primary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d={trainingIncludedIcons[index % trainingIncludedIcons.length]}
                        />
                      </svg>
                    </span>
                    <h3 class="font-heading text-2xl tracking-wide text-white">
                      {feature.title}
                    </h3>
                    <p class="mt-3 text-sm leading-relaxed text-white/70">
                      {feature.body}
                    </p>
                  </article>
                ))}
              </div>

              {detail.highlights && detail.highlights.length > 0 && (
                <ul class="mt-10 grid gap-3 sm:grid-cols-2">
                  {detail.highlights.map((item) => (
                    <li class="flex gap-3 text-sm text-white/75">
                      <svg
                        class="mt-0.5 h-5 w-5 shrink-0 text-primary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </section>
        )
    }

    <!-- What You Will Need (training only) -->
    {
      isTraining && detail?.needs && (
        <section class="mx-auto max-w-3xl px-6 py-16 md:py-20">
          <h2 class="mb-6 font-heading text-3xl tracking-wider text-white md:text-4xl">
            What You Will Need
          </h2>
          <p class="text-base leading-relaxed text-white/75">{detail.needs}</p>
        </section>
      )
    }

    <!-- FAQ -->
    {
      detail?.faqs && detail.faqs.length > 0 && (
        <section
          class:list={[
            isTraining
              ? "border-t border-white/10 bg-surface/40 py-16 md:py-24"
              : "mx-auto max-w-3xl px-6 py-16 md:py-24",
          ]}
        >
          <div class:list={[isTraining && "mx-auto max-w-3xl px-6"]}>
            <h2 class="mb-10 font-heading text-3xl tracking-wider text-white md:text-4xl">
              Frequently Asked Questions
            </h2>
            <div class="space-y-3">
              {detail.faqs.map((faq) => (
                <details
                  class:list={[
                    "group rounded-xl border border-white/10 px-5 py-4 transition-colors hover:border-white/20",
                    isTraining ? "bg-dark" : "bg-surface",
                  ]}
                >
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold text-white">
                    {faq.question}
                    <span
                      class="text-2xl leading-none text-white/40 transition-transform group-open:rotate-45"
                      aria-hidden="true"
                    >
                      +
                    </span>
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed text-white/70">
                    {faq.answer}
                  </p>
                </details>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Bottom CTA -->
    <section
      class:list={[
        isTraining
          ? "mx-auto max-w-7xl px-6 py-16 md:py-24"
          : "border-t border-white/10 bg-surface/40",
      ]}
    >
      <div class:list={[!isTraining && "mx-auto max-w-7xl px-6 py-16 md:py-24"]}>
        <div
          class:list={[
            "flex flex-col items-center gap-6 rounded-2xl border border-white/10 px-8 py-12 text-center",
            isTraining ? "bg-surface" : "bg-dark",
          ]}
        >
          <h2 class="font-heading text-3xl tracking-wider text-white md:text-4xl">
            {ctaTitle}
          </h2>
          <p class="max-w-xl text-white/70">{ctaDescription}</p>
          <p class="font-heading text-4xl tracking-wide text-primary">
            €{product.price}
          </p>
          <div class="w-full max-w-sm">
            <ProgramPurchase
              client:visible
              product={purchaseProduct}
              splits={detail?.splits ?? []}
              optionLabel={purchaseOptionLabel}
            />
          </div>
          <a
            href={ctaBrowseHref}
            class="text-sm text-white/60 underline decoration-white/30 underline-offset-4 transition-colors hover:text-primary"
          >
            {ctaBrowseLabel}
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
