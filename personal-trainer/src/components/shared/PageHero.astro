---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Breadcrumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  breadcrumbs: Breadcrumb[];
  image?: ImageMetadata;
}

const { title, breadcrumbs, image } = Astro.props;
---

<section class="relative overflow-hidden border-b border-white/10 bg-surface">
  {
    image && (
      <>
        <Image
          src={image}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          widths={[640, 960, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          decoding="async"
          quality={75}
          aria-hidden="true"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-dark via-dark/90 to-dark/70"
          aria-hidden="true"
        />
      </>
    )
  }
  <div class="relative mx-auto max-w-7xl px-6 py-12 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-4">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-white/50">
        {
          breadcrumbs.map((crumb, index) => (
            <li class="flex items-center gap-2">
              {index > 0 && <span aria-hidden="true">/</span>}
              {crumb.href ? (
                <a
                  href={crumb.href}
                  class="transition-colors hover:text-primary"
                >
                  {crumb.label}
                </a>
              ) : (
                <span class="text-white/80">{crumb.label}</span>
              )}
            </li>
          ))
        }
      </ol>
    </nav>
    <h1 class="font-heading text-5xl tracking-wider text-white md:text-6xl">
      {title}
    </h1>
  </div>
</section>
