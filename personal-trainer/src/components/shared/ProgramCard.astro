---
import { Image } from "astro:assets";
import type { Product } from "../../data/products";
import { getProductCover } from "../../lib/productImages";
import AddToCartButton from "./AddToCartButton.jsx";

interface Props {
  program: Product;
  basePath?: string;
}

const { program, basePath = "/programs" } = Astro.props;
const cover = getProductCover(program.image);
const href = `${basePath}/${program.id}`;
---

<article
  class="relative flex flex-col overflow-hidden rounded-lg border border-white/10 bg-surface"
>
  {
    program.popular && (
      <span class="absolute right-4 top-4 z-10 rounded bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wider text-dark">
        Most Popular
      </span>
    )
  }

  <a
    href={href}
    class="group block overflow-hidden"
    aria-label={`View ${program.name}`}
  >
    <Image
      src={cover}
      alt={program.name}
      class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
      widths={[400, 600, 800]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading="lazy"
      decoding="async"
      quality={75}
    />
  </a>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-heading text-3xl tracking-wide text-white">
      <a href={href} class="transition-colors hover:text-primary">
        {program.name}
      </a>
    </h3>

    <ul class="mt-4 flex-1 space-y-2">
      {
        program.features.map((feature) => (
          <li class="flex gap-2 text-sm text-white/70">
            <span class="text-primary" aria-hidden="true">✓</span>
            {feature}
          </li>
        ))
      }
    </ul>

    <p class="mt-6 font-heading text-4xl tracking-wide text-primary">
      €{program.price}
    </p>

    <div class="mt-4 flex flex-col gap-3">
      <a
        href={href}
        class="rounded border border-white/20 px-6 py-3 text-center text-sm font-semibold uppercase tracking-wider text-white transition-colors hover:border-primary hover:text-primary"
      >
        View Details
      </a>
      <AddToCartButton
        client:visible
        product={{
          id: program.id,
          name: program.name,
          price: program.price,
          image: program.image,
        }}
      />
    </div>
  </div>
</article>
