---
import { Image } from "astro:assets";
import heroBg from "../../assets/hero_page_start.png";
import Button from "../shared/Button.astro";
---

<section class="relative flex min-h-[68vh] w-full items-center justify-center overflow-hidden md:min-h-[72vh] lg:min-h-[78vh]">
  <Image
    src={heroBg}
    alt="Athlete performing a front squat in the gym"
    class="absolute inset-0 h-full w-full object-cover object-center"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    quality={75}
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/40"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 py-12 text-center md:py-16">
    <h1 class="font-heading text-5xl leading-none tracking-wider text-white md:text-7xl lg:text-8xl">
      TRANSFORM YOUR BODY
    </h1>
    <p class="mt-6 text-lg text-white/80 md:text-xl">
      Science-based training &amp; nutrition programs
    </p>
    <div class="mt-8 flex w-full max-w-md flex-col items-stretch justify-center gap-4 sm:max-w-none sm:flex-row sm:items-center">
      <Button href="/book" class="w-full text-center sm:w-auto">Book a Free Call</Button>
      <Button href="/programs" variant="outline" class="w-full text-center sm:w-auto">
        View Programs
      </Button>
    </div>
  </div>

  <a
    href="#category-cards"
    class="scroll-arrow absolute bottom-8 left-1/2 z-10 -translate-x-1/2 text-white/60 transition-colors hover:text-primary"
    aria-label="Scroll to content"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>
