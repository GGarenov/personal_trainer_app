---
import { Image } from "astro:assets";
import heroBg from "../../assets/image_seven.jpg";
import Button from "../shared/Button.astro";
---

<section class="relative flex min-h-screen w-full items-center justify-center overflow-hidden">
  <Image
    src={heroBg}
    alt="Athlete performing a front squat in the gym"
    class="absolute inset-0 h-full w-full object-cover object-center"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/40"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 py-24 text-center">
    <h1 class="font-heading text-6xl leading-none tracking-wider text-white md:text-8xl lg:text-9xl">
      TRANSFORM YOUR BODY
    </h1>
    <p class="mt-6 text-lg text-white/80 md:text-xl">
      Science-based training &amp; nutrition programs
    </p>
    <div class="mt-10">
      <Button href="/programs">View Programs</Button>
    </div>
  </div>

  <a
    href="#category-cards"
    class="scroll-arrow absolute bottom-8 left-1/2 z-10 -translate-x-1/2 text-white/60 transition-colors hover:text-primary"
    aria-label="Scroll to content"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-8 w-8"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </a>
</section>
