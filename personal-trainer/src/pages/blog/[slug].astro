---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BlogCard from "../../components/blog/BlogCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogCover } from "../../lib/blogImages";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const cover = getBlogCover(post.data.image);

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={`${post.data.title} — Gary Bean`}
  description={post.data.description}
  ogImage={cover}
  ogType="article"
>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <span class="text-xs font-semibold uppercase tracking-wider text-primary">
      {post.data.category}
    </span>
    <h1 class="mt-3 font-heading text-5xl tracking-wider text-white md:text-6xl">
      {post.data.title}
    </h1>
    <p class="mt-4 text-sm text-white/50">
      {post.data.author} · <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
    </p>

    <Image
      src={cover}
      alt={post.data.title}
      class="mt-8 w-full rounded-lg object-cover"
      widths={[640, 960, 1280]}
      sizes="(max-width: 768px) 100vw, 768px"
      loading="eager"
      decoding="async"
      quality={75}
    />

    <div class="prose prose-invert mt-10 max-w-none space-y-5 text-white/80">
      <Content />
    </div>
  </article>

  {
    relatedPosts.length > 0 && (
      <section class="border-t border-white/10 bg-surface py-16 md:py-20">
        <div class="mx-auto max-w-7xl px-6">
          <h2 class="font-heading text-3xl tracking-wider text-white md:text-4xl">
            RELATED POSTS
          </h2>
          <div class="mt-10 grid gap-8 md:grid-cols-3">
            {relatedPosts.map((related) => <BlogCard post={related} />)}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
