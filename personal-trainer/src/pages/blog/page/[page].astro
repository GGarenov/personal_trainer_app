---
import BlogListing from "../../../components/blog/BlogListing.astro";
import PageHero from "../../../components/shared/PageHero.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import heroBlogImage from "../../../assets/blog_banner.jpg";
import {
  getBlogPageCount,
  getBlogPagePosts,
  getSortedBlogPosts,
} from "../../../lib/blog";

export async function getStaticPaths() {
  const allPosts = await getSortedBlogPosts();
  const lastPage = getBlogPageCount(allPosts);

  return Array.from({ length: lastPage - 1 }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const allPosts = await getSortedBlogPosts();
const currentPage = Number(Astro.params.page);
const lastPage = getBlogPageCount(allPosts);
const posts = getBlogPagePosts(allPosts, currentPage);
---

<BaseLayout
  title={`Blog — Page ${currentPage} — Gary Bean`}
  description="Training, nutrition, mindset, and transformation articles."
>
  <main>
    <PageHero
      title="Blog"
      image={heroBlogImage}
      imageClass="object-contain object-center"
      heroClass="min-h-[30vh] md:min-h-[34vh]"
      overlayClass="bg-gradient-to-t from-dark/90 via-dark/25 to-transparent"
    />

    <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="mb-12 max-w-2xl text-lg text-white/70">
        Science-based insights on training, nutrition, and building lasting habits.
      </p>

      <BlogListing
        posts={posts}
        activeCategory="All"
        currentPage={currentPage}
        lastPage={lastPage}
        basePath="/blog"
      />
    </section>
  </main>
</BaseLayout>
