---
import BlogListing from "../../../components/blog/BlogListing.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getBlogPageCount,
  getBlogPagePosts,
  getSortedBlogPosts,
} from "../../../lib/blog";

export async function getStaticPaths() {
  const allPosts = await getSortedBlogPosts();
  const lastPage = getBlogPageCount(allPosts);

  return Array.from({ length: lastPage - 1 }, (_, index) => ({
    params: { page: String(index + 2) },
  }));
}

const allPosts = await getSortedBlogPosts();
const currentPage = Number(Astro.params.page);
const lastPage = getBlogPageCount(allPosts);
const posts = getBlogPagePosts(allPosts, currentPage);
---

<BaseLayout
  title={`Blog — Page ${currentPage} — Gary Bean`}
  description="Training, nutrition, mindset, and transformation articles."
>
  <main class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <h1 class="font-heading text-5xl tracking-wider text-white md:text-6xl">
      BLOG
    </h1>
    <p class="mt-4 max-w-2xl text-white/70">
      Science-based insights on training, nutrition, and building lasting habits.
    </p>

    <BlogListing
      posts={posts}
      activeCategory="All"
      currentPage={currentPage}
      lastPage={lastPage}
      basePath="/blog"
    />
  </main>
</BaseLayout>
