---
import BlogListing from "../../../../components/blog/BlogListing.astro";
import PageHero from "../../../../components/shared/PageHero.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import heroBlogImage from "../../../../assets/blog_banner.jpg";
import {
  blogCategories,
  type BlogCategory,
} from "../../../../lib/blogImages";
import {
  getBlogPageCount,
  getBlogPagePosts,
  getSortedBlogPosts,
} from "../../../../lib/blog";

export async function getStaticPaths() {
  return blogCategories.map((category) => ({
    params: { category },
  }));
}

const category = Astro.params.category as BlogCategory;
const allPosts = (await getSortedBlogPosts()).filter(
  (post) => post.data.category === category,
);
const lastPage = getBlogPageCount(allPosts);
const posts = getBlogPagePosts(allPosts, 1);
const basePath = `/blog/category/${category}`;
---

<BaseLayout
  title={`${category} — Blog — Gary Bean`}
  description={`${category} articles on training, nutrition, and performance.`}
>
  <main>
    <PageHero
      title="Blog"
      image={heroBlogImage}
      imageClass="object-contain object-center"
      heroClass="min-h-[30vh] md:min-h-[34vh]"
      overlayClass="bg-gradient-to-t from-dark/90 via-dark/25 to-transparent"
    />

    <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="mb-12 max-w-2xl text-lg text-white/70">
        Science-based insights on training, nutrition, and building lasting habits.
      </p>

      <BlogListing
        posts={posts}
        activeCategory={category}
        currentPage={1}
        lastPage={lastPage}
        basePath={basePath}
      />
    </section>
  </main>
</BaseLayout>
