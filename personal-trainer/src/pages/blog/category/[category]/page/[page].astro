---
import BlogListing from "../../../../../components/blog/BlogListing.astro";
import PageHero from "../../../../../components/shared/PageHero.astro";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import heroBlogImage from "../../../../../assets/blog_banner.png";
import { blogCategories, type BlogCategory } from "../../../../../lib/blogImages";
import {
  BLOG_HERO_CLASS,
  categoryToSlug,
  getBlogPageCount,
  getBlogPagePosts,
  getCategoryBasePath,
  getSortedBlogPosts,
  slugToCategory,
} from "../../../../../lib/blog";

export async function getStaticPaths() {
  const allPosts = await getSortedBlogPosts();
  const paths = [];

  for (const category of blogCategories) {
    const categoryPosts = allPosts.filter((post) => post.data.category === category);
    const lastPage = getBlogPageCount(categoryPosts);

    for (let page = 2; page <= lastPage; page++) {
      paths.push({
        params: { category: categoryToSlug(category), page: String(page) },
      });
    }
  }

  return paths;
}

const categorySlug = Astro.params.category!;
const category = slugToCategory(categorySlug) as BlogCategory;
const currentPage = Number(Astro.params.page);
const allPosts = (await getSortedBlogPosts()).filter(
  (post) => post.data.category === category,
);
const lastPage = getBlogPageCount(allPosts);
const posts = getBlogPagePosts(allPosts, currentPage);
const basePath = getCategoryBasePath(category);
---

<BaseLayout
  title={`${category} — Blog — Page ${currentPage} — George Stevens`}
  description={`${category} articles on training, nutrition, and performance.`}
>
  <main>
    <PageHero
      title="Blog"
      image={heroBlogImage}
      imageClass="object-contain object-center"
      heroClass={BLOG_HERO_CLASS}
      overlayClass="bg-gradient-to-t from-dark/90 via-dark/25 to-transparent"
    />

    <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="mb-12 max-w-2xl text-lg text-white/70">
        Science-based insights on training, nutrition, and building lasting habits.
      </p>

      <BlogListing
        posts={posts}
        activeCategory={category}
        currentPage={currentPage}
        lastPage={lastPage}
        basePath={basePath}
      />
    </section>
  </main>
</BaseLayout>
