---
import BlogListing from "../../../../../components/blog/BlogListing.astro";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { type BlogCategory } from "../../../../../lib/blogImages";
import {
  getBlogPageCount,
  getBlogPagePosts,
  getSortedBlogPosts,
} from "../../../../../lib/blog";

export async function getStaticPaths() {
  const categories = ["Training", "Nutrition", "Mindset", "Transformations"] as const;
  const allPosts = await getSortedBlogPosts();
  const paths = [];

  for (const category of categories) {
    const categoryPosts = allPosts.filter((post) => post.data.category === category);
    const lastPage = getBlogPageCount(categoryPosts);

    for (let page = 2; page <= lastPage; page++) {
      paths.push({
        params: { category, page: String(page) },
      });
    }
  }

  return paths;
}

const category = Astro.params.category as BlogCategory;
const currentPage = Number(Astro.params.page);
const allPosts = (await getSortedBlogPosts()).filter(
  (post) => post.data.category === category,
);
const lastPage = getBlogPageCount(allPosts);
const posts = getBlogPagePosts(allPosts, currentPage);
const basePath = `/blog/category/${category}`;
---

<BaseLayout
  title={`${category} — Blog — Page ${currentPage} — Gary Bean`}
  description={`${category} articles on training, nutrition, and performance.`}
>
  <main class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <h1 class="font-heading text-5xl tracking-wider text-white md:text-6xl">
      BLOG
    </h1>
    <p class="mt-4 max-w-2xl text-white/70">
      Science-based insights on training, nutrition, and building lasting habits.
    </p>

    <BlogListing
      posts={posts}
      activeCategory={category}
      currentPage={currentPage}
      lastPage={lastPage}
      basePath={basePath}
    />
  </main>
</BaseLayout>
