---
import heroNutritionImage from "../assets/nutrition_banner.jpg";
import ProgramCard from "../components/shared/ProgramCard.astro";
import PageHero from "../components/shared/PageHero.astro";
import { nutritionPlans } from "../data/products";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Nutrition Plans — George Stevens"
  description="Science-based nutrition plans for weight loss, muscle gain, and sustainable eating."
>
  <main>
    <PageHero
      title="Nutrition Plans"
      image={heroNutritionImage}
      imageClass="object-contain object-center"
      overlayClass="bg-gradient-to-t from-dark/90 via-dark/25 to-transparent"
    />

    <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="mb-12 max-w-2xl text-lg text-white/70">
        Practical meal plans built on macro science and real-world eating habits
        — pick the plan that matches your goal and lifestyle.
      </p>

      <div class="grid gap-8 md:grid-cols-2">
        {
          nutritionPlans.map((plan) => (
            <ProgramCard program={plan} basePath="/nutrition" />
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
