---
import CategoryCards from "../components/home/CategoryCards.astro";
import Hero from "../components/home/Hero.astro";
import RecentBlogPosts from "../components/home/RecentBlogPosts.astro";
import TransformationSlider from "../components/home/TransformationSlider.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";

import afterOne from "../assets/after_one.png";
import afterThree from "../assets/after_three.png";
import afterTwo from "../assets/after_two.png";
import beforeOne from "../assets/before_one.png";
import beforeThree from "../assets/before_three.png";
import beforeTwo from "../assets/before_two.png";

const slides = [
  {
    before: beforeOne.src,
    beforeWidth: beforeOne.width,
    beforeHeight: beforeOne.height,
    after: afterOne.src,
    afterWidth: afterOne.width,
    afterHeight: afterOne.height,
    quote:
      "I never thought I could enjoy the gym. George's program changed everything — I'm stronger and more confident than ever.",
    name: "John Smith",
    result: "Lost 15 kg",
  },
  {
    before: beforeTwo.src,
    beforeWidth: beforeTwo.width,
    beforeHeight: beforeTwo.height,
    after: afterTwo.src,
    afterWidth: afterTwo.width,
    afterHeight: afterTwo.height,
    quote:
      "I gained muscle without living in the gym. The programming is smart, efficient, and actually sustainable.",
    name: "David Mereth",
    result: "Lost 35 kg",
  },
  {
    before: beforeThree.src,
    beforeWidth: beforeThree.width,
    beforeHeight: beforeThree.height,
    after: afterThree.src,
    afterWidth: afterThree.width,
    afterHeight: afterThree.height,
    quote:
      "The nutrition plan was simple to follow and the results spoke for themselves. Best investment I've made in myself.",
    name: "Maria Lopez",
    result: "Lost 8 kg muscle",
  },
];
---

<BaseLayout
  title="Gary Bean — Personal Trainer"
  description="Science-based training and nutrition programs to transform your body."
>
  <main>
    <Hero />
    <CategoryCards />

    <section class="mx-auto max-w-7xl px-6 py-20 md:py-28">
      <h2
        class="mb-12 text-center font-heading text-4xl tracking-wider text-white md:text-5xl"
      >
        CLIENT TRANSFORMATIONS
      </h2>
      <TransformationSlider client:visible slides={slides} />
    </section>

    <RecentBlogPosts />
  </main>
</BaseLayout>
