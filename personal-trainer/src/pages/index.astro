---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Personal Trainer">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-5xl tracking-wide text-primary">Train smarter</h1>
    <p class="mt-4 text-lg text-white/80">
      Body copy uses DM Sans via <code class="text-primary">font-body</code>.
      Headings use Bebas Neue via <code class="text-primary">font-heading</code>.
    </p>
  </main>
</BaseLayout>
