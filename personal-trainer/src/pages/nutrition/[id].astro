---
import ProductDetailPage from "../../components/program/ProductDetailPage.astro";
import { nutritionPlans, type Product } from "../../data/products";

export async function getStaticPaths() {
  return nutritionPlans.map((plan) => ({
    params: { id: plan.id },
    props: { plan },
  }));
}

interface Props {
  plan: Product;
}

const { plan } = Astro.props;
---

<ProductDetailPage
  product={plan}
  parentHref="/nutrition"
  parentLabel="Nutrition Plans"
  variant="nutrition"
/>
