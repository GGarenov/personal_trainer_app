---
import CheckoutForm from "../components/checkout/CheckoutForm.jsx";
import OrderSummary from "../components/checkout/OrderSummary.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Checkout — George Stevens"
  description="Complete your demo order for training programs and nutrition plans."
>
  <main>
    <div
      class="border-b border-primary/30 bg-primary/10 px-6 py-4 text-center"
      role="status"
    >
      <p class="text-sm font-semibold uppercase tracking-wider text-primary">
        Demo checkout — no real payment is processed
      </p>
    </div>

    <section class="mx-auto max-w-7xl px-6 py-12 md:py-16">
      <h1 class="font-heading text-5xl tracking-wider text-white md:text-6xl">
        Checkout
      </h1>
      <p class="mt-3 max-w-2xl text-white/60">
        Fill in your details below to complete this training demo. No charges
        will be made.
      </p>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-12">
        <CheckoutForm client:load />
        <div class="lg:sticky lg:top-8 lg:self-start">
          <OrderSummary client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
