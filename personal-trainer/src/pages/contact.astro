---
import heroContactImage from "../assets/contact_banner.png";
import ContactForm from "../components/contact/ContactForm";
import PageHero from "../components/shared/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — George Stevens"
  description="Get in touch about training programs, nutrition plans, or coaching inquiries."
>
  <main>
    <PageHero
      title="Contact"
      image={heroContactImage}
      imageClass="object-cover object-[center_22%]"
    />

    <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="font-heading text-4xl tracking-wider text-white">
            LET&apos;S WORK TOGETHER
          </h2>
          <p class="mt-4 text-white/70">
            Have a question about a program, want to discuss coaching, or just
            want to say hello? Fill out the form and I&apos;ll get back to you
            within 24–48 hours.
          </p>

          <div class="mt-10 space-y-6">
            <div>
              <h3
                class="text-xs font-semibold uppercase tracking-wider text-primary"
              >
                Email
              </h3>
              <a
                href="mailto:gary@garybean.com"
                class="mt-2 inline-block text-lg text-white transition-colors hover:text-primary"
              >
                support@georgefitness.com
              </a>
            </div>

            <div>
              <h3
                class="text-xs font-semibold uppercase tracking-wider text-primary"
              >
                Location
              </h3>
              <p class="mt-2 text-white/70">
                Los Angeles, CA · Online coaching worldwide
              </p>
            </div>

            <div>
              <h3
                class="text-xs font-semibold uppercase tracking-wider text-primary"
              >
                Follow Me
              </h3>
              <div class="mt-4 flex gap-5">
                <a
                  href="#"
                  aria-label="Instagram"
                  class="text-white/60 transition-colors hover:text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                    <circle cx="12" cy="12" r="4"></circle>
                    <circle cx="17.5" cy="6.5" r="1"></circle>
                  </svg>
                </a>

                <a
                  href="#"
                  aria-label="YouTube"
                  class="text-white/60 transition-colors hover:text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M23 12s0-3.5-.4-5.2c-.2-.9-.9-1.6-1.8-1.8C19.1 4.5 12 4.5 12 4.5s-7.1 0-8.8.5c-.9.2-1.6.9-1.8 1.8C1 8.5 1 12 1 12s0 3.5.4 5.2c.2.9.9 1.6 1.8 1.8 1.7.5 8.8.5 8.8.5s7.1 0 8.8-.5c.9-.2 1.6-.9 1.8-1.8.4-1.7.4-5.2.4-5.2z"
                    ></path>
                    <path fill="black" d="M10 15.5v-7l6 3.5z"></path>
                  </svg>
                </a>

                <a
                  href="#"
                  aria-label="Facebook"
                  class="text-white/60 transition-colors hover:text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M14 8h3V4h-3c-3 0-5 2-5 5v3H6v4h3v8h4v-8h3l1-4h-4v-3c0-.7.3-1 1-1z"
                    ></path>
                  </svg>
                </a>

                <a
                  href="#"
                  aria-label="TikTok"
                  class="text-white/60 transition-colors hover:text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M16 3c.3 2.2 1.5 3.7 4 4v3c-1.4 0-2.7-.4-4-1.2V16c0 3.3-2.7 6-6 6s-6-2.7-6-6 2.7-6 6-6c.3 0 .6 0 .9.1v3.2c-.3-.1-.6-.2-.9-.2-1.7 0-3 1.3-3 3s1.3 3 3 3 3-1.3 3-3V3h3z"
                    ></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-lg border border-white/10 bg-surface p-6 md:p-8">
          <h2 class="mb-6 font-heading text-3xl tracking-wider text-white">
            SEND A MESSAGE
          </h2>
          <ContactForm client:load />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
