---
import ProductDetailPage from "../../components/program/ProductDetailPage.astro";
import { trainingPrograms, type Product } from "../../data/products";

export async function getStaticPaths() {
  return trainingPrograms.map((program) => ({
    params: { id: program.id },
    props: { program },
  }));
}

interface Props {
  program: Product;
}

const { program } = Astro.props;
---

<ProductDetailPage
  product={program}
  parentHref="/programs"
  parentLabel="Training Programs"
  variant="training"
/>
